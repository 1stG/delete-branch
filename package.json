    "eslint-plugin-graphql": "^3.1.1",
    "husky": "^3.1.0",
    "jest": "^24.8.0",
    "jest-transform-graphql": "^2.1.0",
    "lint-staged": "^9.5.0",
    "prettier": "^1.19.1",
    "prettier-config-1stg": "^0.2.0",
    "standard-version": "^6.0.1",
